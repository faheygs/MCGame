# .gitattributes - MCGame project
# Tells git how to handle text vs binary files, line endings, and merge strategies.

# ============================================================
# Auto-detect text files; normalize line endings to LF in repo
# ============================================================
* text=auto eol=lf

# ============================================================
# C# / .NET source
# ============================================================
*.cs           text diff=csharp
*.csproj       text merge=union
*.sln          text eol=crlf merge=union

